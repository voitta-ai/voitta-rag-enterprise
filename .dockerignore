# Keep the build context lean — anything below either bloats the image or
# leaks dev-only state into it.

# VCS + dev caches
.git
.github
.venv
venv
.mypy_cache
.pytest_cache
.ruff_cache
__pycache__
**/__pycache__
*.pyc

# Local data + secrets
.env
.env.local
data/
voitta-data/
qdrant-data/
users.txt

# Compose files aren't needed inside the image
docker-compose.yml
docker-compose.override.yml

# Build artefacts
build/
dist/
*.egg-info

# Tests are not needed at runtime; the image ships only the app.
tests/

# Editor
.vscode/
.idea/
.DS_Store

# Terraform — copied into images by accident otherwise
terraform/
