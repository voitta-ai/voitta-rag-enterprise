# .env.terraform — Tier A infra config.
#
# Copy this file to `.env.terraform` (gitignored), fill in values, and
# the `make deploy-*` targets will source it before invoking terraform.
# Each TF_VAR_* maps to a `variable "<name>"` declaration in
# variables.tf.
#
# Authentication is NOT here. Run `gcloud auth application-default login`
# once on the operator workstation; the google provider picks it up.

# ----- Required -----

# GCP project ID (NOT the project number/name).
TF_VAR_project_id=my-gcp-project-id

# ----- Region / zone -----

TF_VAR_region=us-central1
TF_VAR_zone=us-central1-a

# ----- Naming -----

# Prefix for all resource names. Change it if you run more than one
# stack in the same project.
TF_VAR_name_prefix=voitta-rag

# ----- TLS / domain -----

# Hostname the app serves under. Caddy auto-issues a Let's Encrypt
# cert for it. Customer MUST point an A record at the static IP
# (terraform output `vm_external_ip`) BEFORE first apply or the ACME
# challenge fails. Leave empty to bring Caddy up without TLS for
# smoke testing only.
TF_VAR_domain=voitta.example.com

# false (default): Caddy on the VM does TLS — cheap, no LB cost.
# true: Cloud LB + Google-managed cert (issue #6). Caddy is skipped.
TF_VAR_create_load_balancer=false

# Extra hostnames on the managed SSL cert (only used when
# create_load_balancer=true). Each must DNS-resolve to the LB IP
# before terraform apply, or cert provisioning stalls. Empty list
# default. HCL list syntax in single quotes:
#   TF_VAR_domain_aliases='["www.voitta.example.com"]'
TF_VAR_domain_aliases=[]

# ----- Encryption (CMEK) -----

# When true, disks (boot + data) are encrypted with a Cloud KMS
# customer-managed key instead of the default Google-managed key.
# Same key is used for Secret Manager (#8) and app-level envelope
# encryption (#10). One-way switch: once on, you cannot turn off
# without recreating the encrypted resources.
TF_VAR_enable_cmek=false

# KMS keyring + key names. Created when enable_cmek=true. 90-day
# auto-rotation is hardcoded.
TF_VAR_kms_keyring=voitta
TF_VAR_kms_key=disk-and-secrets

# ----- Backups -----

# UTC hour the daily snapshot policy fires (0-23). 03:00 UTC by
# default — pick a low-traffic window for your workload.
TF_VAR_snapshot_hour=3

# Days GCP keeps each automatic snapshot before deleting it.
TF_VAR_snapshot_retention_days=7

# ----- Image -----

# Public GHCR image published by the release workflow (#2). Customers
# who mirror into their own Artifact Registry override this.
TF_VAR_image_repo=ghcr.io/voitta-ai/voitta-rag-enterprise

# Tag to pull on first boot. Pin to a real release for production;
# `latest` is for casual eval. Subsequent upgrades go through
# `make deploy-upgrade` (#13), not by changing this.
TF_VAR_image_tag=latest

# ----- Compute -----

# Tier A default. Bump to g2-standard-4 for Tier B (with an L4 GPU,
# attached separately in a future issue).
TF_VAR_machine_type=e2-standard-4

# Data disk (CAS + SQLite + Qdrant + model cache).
TF_VAR_disk_size_gb=200
TF_VAR_disk_type=pd-balanced

# Boot disk. COS by default; switch to an Ubuntu LTS image if you
# prefer a richer base.
TF_VAR_boot_disk_image=projects/cos-cloud/global/images/family/cos-stable
TF_VAR_boot_disk_size_gb=30

# ----- Network -----

# Internal subnet CIDR. Pick something that doesn't overlap with your
# existing networks if you're peering.
TF_VAR_subnet_cidr=10.20.0.0/24

# CIDRs allowed to reach 80/443. Default opens to the internet; restrict
# for internal-only deployments. Use HCL list syntax in single quotes:
#   TF_VAR_ingress_cidrs_http='["10.0.0.0/8"]'
TF_VAR_ingress_cidrs_http=["0.0.0.0/0"]
