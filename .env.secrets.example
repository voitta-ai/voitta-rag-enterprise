# .env.secrets — values for the secrets declared in
# deploy/terraform/secrets.tf.
#
# Copy this file to `.env.secrets` (gitignored), fill in values, run
# `make deploy-secrets` (issue #12) which calls
# deploy/scripts/populate_secrets.sh. Each run adds a new version of
# every secret; the latest is what the app reads at boot.
#
# DO NOT commit `.env.secrets`. The .gitignore covers it but check.

# Sign in with Google. Get these from
# https://console.cloud.google.com/apis/credentials by creating a
# "Web application" OAuth client. Add
# https://<your-domain>/api/auth/google/callback as an authorized
# redirect URI. Leave blank to skip OAuth (single-user / dev modes).
voitta-google-auth-client-id=
voitta-google-auth-client-secret=

# HMAC key for the SPA's session cookie. Pick something long and
# random; rotation force-logs-out everyone (acceptable side effect of
# a real rotation event).
#   openssl rand -base64 48
voitta-session-secret=

# Optional embedder version overrides. Only set these when migrating
# to a new model — bumping triggers a full re-embed (issue #15
# documents the procedure). Leave blank to use the in-image defaults.
voitta-dense-version=
voitta-sparse-version=
voitta-image-version=
