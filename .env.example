# ---------------------------------------------------------------------------
# Docker Compose deploy (see docker-compose.yml + README "Deploy with Docker
# Compose"). The first group is consumed by compose itself; the rest are the
# minimum APP settings a single-box deploy needs.
# ---------------------------------------------------------------------------
# MINIMUM CONFIG for a private single-box deploy — without these you hit a login
# wall and a dimmed "New folder" button:
#   1. an auth mode:
# VOITTA_SINGLE_USER=true
#   2. the managed-folder root (REQUIRED; under /data so it persists):
# VOITTA_ROOT_PATH=/data/folders
#
# Pull a prebuilt image instead of building locally. Leave unset to build from
# the Dockerfile.
# VOITTA_IMAGE=ghcr.io/voitta-ai/voitta-rag-enterprise:latest
# Host port mapped to the container's 8000 (container port is fixed).
# VOITTA_HOST_PORT=8000
# Host path (or named volume) backing /data inside the container. All
# persistent state lives here: SQLite DB, CAS blobs, embedded Qdrant, secrets.
# VOITTA_DATA_PATH=./voitta-data
# Host path backing standalone Qdrant storage (only if you enable the optional
# qdrant service in docker-compose.yml).
# VOITTA_QDRANT_PATH=./qdrant-data

# Storage
VOITTA_DATA_DIR=~/.voitta-image-rag
# VOITTA_DB_PATH=
# VOITTA_CAS_DIR=
# VOITTA_QDRANT_PATH=

# Qdrant backend: "embedded" (default, SQLite-backed local store) or
# "standalone" (external Qdrant server — recommended for > 20 k points).
# When set to "standalone", VOITTA_QDRANT_URL is required.
# VOITTA_QDRANT_MODE=embedded
# VOITTA_QDRANT_URL=http://192.168.88.212:6335

# Optional parent for managed folders. POST /api/folders {"name": "x"}
# creates ${VOITTA_ROOT_PATH}/x and registers it as managed (sync-capable).
# Folders registered by absolute "path" are external and never synced.
# VOITTA_ROOT_PATH=/data/voitta-image-rag/fs

# Network
VOITTA_PORT=8000
VOITTA_MCP_PORT=8001
# Public base URL this API is reachable at — used to prefix signed
# asset URLs (CAD projections, page renders, …) returned to MCP
# clients. Leave unset for local dev: relative ``/api/assets/<token>``
# paths still work when the MCP proxy adds the host. Set in
# production so remote clients can fetch directly.
# VOITTA_PUBLIC_BASE_URL=https://enterprise.voitta.ai

# Workers (blank = cpu_count)
# VOITTA_WORKERS=

# Models
VOITTA_DENSE_MODEL=intfloat/e5-base-v2
VOITTA_SPARSE_MODEL=Qdrant/bm25
VOITTA_IMAGE_MODEL=google/siglip2-base-patch16-224

# Versions stamped onto Qdrant points (bump to trigger a re-embed migration)
VOITTA_DENSE_VERSION=e5-base-v2@1
VOITTA_SPARSE_VERSION=bm25@1
VOITTA_IMAGE_VERSION=siglip2-base@1

# Indexing
VOITTA_NEARBY_RADIUS=2
VOITTA_MAX_FILE_BYTES=1073741824
# Glob patterns matched against any path component. Match → skip. The
# default covers VCS clutter, voitta sidecars, common media + archive
# blobs, and ML-weight files. Override only if you really mean it; the
# default protects you from indexing 4 GB mp4s and 800 MB safetensors.
# VOITTA_IGNORE_PATTERNS=...

# PDF parsing — see services/parsers/pdf_parser.py
# VOITTA_PDF_PAGES_PER_BUCKET=20
# VOITTA_PDF_PARSE_METHOD=auto       # auto | txt | ocr
# VOITTA_PDF_PARSE_TIMEOUT_S=600     # kill MinerU subprocess after this many seconds

# Auth — pick one. See ARCHITECTURE.md §9.
VOITTA_SINGLE_USER=false
# VOITTA_DEV_USER=root@localhost
VOITTA_USERS_FILE=users.txt

# "Sign in with Google" — set both to enable interactive login. The
# OAuth client must be type "Web application"; register
# https://<host>/api/auth/google/callback as an Authorized redirect URI.
# VOITTA_GOOGLE_AUTH_CLIENT_ID=
# VOITTA_GOOGLE_AUTH_CLIENT_SECRET=
# VOITTA_SESSION_SECRET=                  # auto-generated under data_dir if blank
# VOITTA_SESSION_MAX_AGE_SECONDS=2592000  # 30 days

# Clerk (clerk.com) Backend API — read users/organizations/memberships from
# your Clerk instance. Secret key from Clerk Dashboard → Configure → API Keys
# (sk_test_… = Development instance, sk_live_… = Production; each instance
# has its own directory). Server-side only. Either name works:
# CLERK_SECRET_KEY=
# VOITTA_CLERK_SECRET_KEY=
# VOITTA_CLERK_API_BASE=https://api.clerk.com/v1

# Sign-in allowlist. Comma-separated domains. The OAuth callback admits an
# email iff its domain is listed here OR its address appears in
# VOITTA_USERS_FILE. With both lists empty every sign-in is rejected — set
# at least one of these before exposing Google login publicly.
# VOITTA_ALLOWED_DOMAINS=customer.com,partner.org
