# Storage
VOITTA_DATA_DIR=~/.voitta-image-rag
# VOITTA_DB_PATH=
# VOITTA_CAS_DIR=
# VOITTA_QDRANT_PATH=
# VOITTA_QDRANT_URL=http://localhost:6333

# Optional parent for managed folders. POST /api/folders {"name": "x"}
# creates ${VOITTA_ROOT_PATH}/x and registers it as managed (sync-capable).
# Folders registered by absolute "path" are external and never synced.
# VOITTA_ROOT_PATH=/data/voitta-image-rag/fs

# Network
VOITTA_PORT=8000
VOITTA_MCP_PORT=8001

# Workers (blank = cpu_count)
# VOITTA_WORKERS=

# Models
VOITTA_DENSE_MODEL=intfloat/e5-base-v2
VOITTA_SPARSE_MODEL=Qdrant/bm25
VOITTA_IMAGE_MODEL=google/siglip2-base-patch16-224

# Versions stamped onto Qdrant points (bump to trigger a re-embed migration)
VOITTA_DENSE_VERSION=e5-base-v2@1
VOITTA_SPARSE_VERSION=bm25@1
VOITTA_IMAGE_VERSION=siglip2-base@1

# Indexing
VOITTA_NEARBY_RADIUS=2
VOITTA_MAX_FILE_BYTES=1073741824
# Glob patterns matched against any path component. Match → skip. The
# default covers VCS clutter, voitta sidecars, common media + archive
# blobs, and ML-weight files. Override only if you really mean it; the
# default protects you from indexing 4 GB mp4s and 800 MB safetensors.
# VOITTA_IGNORE_PATTERNS=...

# PDF parsing — see services/parsers/pdf_parser.py
# VOITTA_PDF_PAGES_PER_BUCKET=20
# VOITTA_PDF_PARSE_METHOD=auto       # auto | txt | ocr
# VOITTA_PDF_PARSE_TIMEOUT_S=600     # kill MinerU subprocess after this many seconds

# Auth — pick one. See ARCHITECTURE.md §9.
VOITTA_SINGLE_USER=false
# VOITTA_DEV_USER=root@localhost
VOITTA_USERS_FILE=users.txt

# "Sign in with Google" — set both to enable interactive login. The
# OAuth client must be type "Web application"; register
# https://<host>/api/auth/google/callback as an Authorized redirect URI.
# VOITTA_GOOGLE_AUTH_CLIENT_ID=
# VOITTA_GOOGLE_AUTH_CLIENT_SECRET=
# VOITTA_SESSION_SECRET=                  # auto-generated under data_dir if blank
# VOITTA_SESSION_MAX_AGE_SECONDS=2592000  # 30 days

# Cloud KMS resource name. When set, the secret columns of
# folder_sync_sources (gh_pat, gh_token, gd_client_secret,
# gd_refresh_token, gd_service_account_json) are encrypted at rest
# via direct KMS encrypt/decrypt. Format:
#   projects/<id>/locations/<region>/keyRings/<name>/cryptoKeys/<key>
# Leave unset for dev — columns store plaintext (warning logged once).
# VOITTA_KMS_KEY=projects/my-project/locations/us-central1/keyRings/voitta/cryptoKeys/disk-and-secrets
