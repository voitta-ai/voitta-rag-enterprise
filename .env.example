# Storage
VOITTA_DATA_DIR=~/.voitta-image-rag
# VOITTA_DB_PATH=
# VOITTA_CAS_DIR=
# VOITTA_QDRANT_PATH=
# VOITTA_QDRANT_URL=http://localhost:6333

# Optional parent for managed folders. POST /api/folders {"name": "x"}
# creates ${VOITTA_ROOT_PATH}/x and registers it as managed (sync-capable).
# Folders registered by absolute "path" are external and never synced.
# VOITTA_ROOT_PATH=/data/voitta-image-rag/fs

# Network
VOITTA_PORT=8000
VOITTA_MCP_PORT=8001

# Workers (blank = cpu_count)
# VOITTA_WORKERS=

# Models
VOITTA_DENSE_MODEL=intfloat/e5-base-v2
VOITTA_SPARSE_MODEL=Qdrant/bm25
VOITTA_IMAGE_MODEL=google/siglip2-base-patch16-224

# Versions stamped onto Qdrant points (bump to trigger a re-embed migration)
VOITTA_DENSE_VERSION=e5-base-v2@1
VOITTA_SPARSE_VERSION=bm25@1
VOITTA_IMAGE_VERSION=siglip2-base@1

# Indexing
VOITTA_NEARBY_RADIUS=2
VOITTA_MAX_FILE_BYTES=1073741824
VOITTA_IGNORE_PATTERNS=.git,node_modules,.DS_Store,__pycache__,.venv,*.tmp

# Auth — pick one. See ARCHITECTURE.md §9.
VOITTA_SINGLE_USER=false
# VOITTA_DEV_USER=root@localhost
VOITTA_USERS_FILE=users.txt
