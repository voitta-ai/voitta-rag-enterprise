# Copy this to terraform.tfvars and fill in the customer-specific values.
# Do NOT commit terraform.tfvars — it contains the OAuth client secret.

project_id = "customer-prod-12345"
region     = "us-central1"
zone       = "us-central1-a"

# Stable identifier for this deployment. Used as the prefix for cluster,
# PVC, ingress, IP. Pick once and don't change — renaming means a
# destroy-then-create.
name = "acme-rag"

# Image pinned by version tag. Bump and re-apply to upgrade.
image_uri = "ghcr.io/voitta-ai/voitta-rag-enterprise:v0.1.0"

# Sign-in allowlist. The OAuth callback admits an email iff its domain is
# listed here OR its address appears in extra_users below. Empty + empty
# denies every sign-in.
allowed_domains = ["acme.com"]
extra_users     = [
  # "consultant@gmail.com",
]

# OAuth credentials from the customer's Google Cloud Console > APIs &
# Services > Credentials. The redirect URI to register is output as
# `redirect_uri` after the first apply.
google_oauth_client_id     = "xxxxxxxx-yyyyyyy.apps.googleusercontent.com"
google_oauth_client_secret = "GOCSPX-zzzzzzzzzzzzzzzzzzz"
