# Terraform local state + per-customer secrets. Modules are committed;
# everything below stays out of git.
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/terraform.tfvars
**/*.auto.tfvars
**/backend.tf
**/tfplan

# UI build outputs (Stage 5)
static/dist/
node_modules/

# Editor
.vscode/
.idea/
.DS_Store
uv.lock

# macOS desktop app (Briefcase) — build artifacts & build-staged copies.
# Source lives in src/voitta_rag_desktop/ + desktop/{build_app.sh,pyproject.toml,
# make_menubar_icon.py}; everything below is regenerated by build_app.sh.
desktop/build/
desktop/dist/
desktop/src/
desktop/wheels/
desktop/*.app/
wheels/
src/voitta_rag_desktop/__pycache__/
src/voitta_rag_desktop/resources/static/

# Local managed-Qdrant runtime state (binary + init marker)
.local/
.qdrant-initialized
